{
  "name": "kick-song-battle",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.0.9",
  "scripts": {
    "dev": "pnpm --filter @sb/overlay build && pnpm --filter @sb/desktop tauri dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "eslint .",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "web": "turbo run dev",
    "overlay:build": "pnpm --filter @sb/overlay build"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.18.0"
  }
}
